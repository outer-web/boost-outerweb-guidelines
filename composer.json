{
  "name": "outerweb/boost-outerweb-guidelines",
  "description": "Outerweb's Laravel & PHP coding guidelines for Laravel Boost",
  "keywords": [
    "laravel",
    "boost",
    "guidelines"
  ],
  "homepage": "https://github.com/outer-web/boost-outerweb-guidelines",
  "license": "MIT",
  "authors": [
    {
      "name": "Simon Broekaert",
      "email": "info@outerweb.be",
      "homepage": "https://outerweb.be",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
  },
  "autoload": {
    "psr-4": {
      "Outerweb\\BoostOuterwebGuidelines\\": "src"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Outerweb\\BoostOuterwebGuidelines\\BoostOuterwebGuidelinesServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}